# ─── Groq API Key (required) ──────────────────────────────────────────────────
# Get a FREE key at https://console.groq.com
# Models used (all open-source, all free on Groq):
#   STT:    whisper-large-v3         (OpenAI Whisper)
#   LLM:    llama-3.3-70b-versatile  (Meta Llama 3.3)
#   Fast:   llama-3.1-8b-instant     (Meta Llama 3.1)
#   Vision: llama-3.2-11b-vision-preview (Meta Llama 3.2)
GROQ_API_KEY=your_groq_api_key_here

# ─── OpenWeatherMap API Key (optional) ────────────────────────────────────────
# Get a free key at https://openweathermap.org/api
# Enables weather-aware disease risk assessment
OPENWEATHER_API_KEY=

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change_this_to_a_secure_random_string
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── STT Backend ──────────────────────────────────────────────────────────────
# "groq"  = uses Groq Whisper API (recommended, fast, free)
# "local" = uses faster-whisper on CPU (no API needed, slower)
WHISPER_BACKEND=groq
WHISPER_MODEL_SIZE=small

# ─── Paths ────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./farmvoice.db
CHROMA_DB_PATH=./chroma_db
